# Required — Anthropic server-side key (never exposed to browser via proxy)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — add for server-side fallback on these providers.
# Users can also enter their own keys in the app's Settings panel.
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
